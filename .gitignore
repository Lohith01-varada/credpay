node_modules/
dist/
dist-ssr/
*.local
.env
.env.*
!.env.example
.DS_Store
*.log
.vite/
# Local .terraform directories (contains provider binaries and plugins)
.terraform/

# .tfstate files (contains absolute state data and sensitive secrets)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all variable files which likely contain sensitive secrets
*.tfvars
*.tfvars.json

# Ignore override files used for local modifications
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore transient lock info files created during terraform apply
.terraform.tfstate.lock.info

# Ignore local CLI configuration files
.terraformrc
terraform.rc
